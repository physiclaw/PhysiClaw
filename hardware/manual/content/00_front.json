          "zh": "1.0 mm"
        }
      },
      {
        "k": {
          "en": "Surface Finish",
          "zh": "表面处理"
        },
        "v": {
          "en": "Raw / as-printed",
          "zh": "打印原样，不做后处理"
        }
      }
    ],
    "notesAfter": [
      {
        "h3": {
          "en": "File naming",
          "zh": "文件命名"
        },
        "body": {
          "en": "Any file whose name ends in <span class=\"ref\">_x#</span> tells you the quantity of that part required to build the machine — for example a part named <span class=\"ref\">idler_mount_front_x2.step</span> is needed two times.",
          "zh": "文件名以 <span class=\"ref\">_x#</span> 结尾时，末尾的数字就表示组装整机要用到几个这种零件——比如 <span class=\"ref\">idler_mount_front_x2.step</span>，就要两个。"
        },
        "classes": "note"
      }
    ]
  }
