    "notes": [
      {
        "h3": { "en": "Square before final tightening", "zh": "终拧前先校正方正度" },
        "body": { "en": "Each screw drops through the long's counterbore and threads into the short's end hole. Run all 8 in, then square the frame on a flat surface before final tightening.", "zh": "每颗螺钉穿过长型材的沉孔，旋入短型材的端面孔。先把 8 颗全部拧上，在平整台面上校正框架方正度，再做终拧。" },
        "classes": "note overlay sm",
        "style": "right:16mm; bottom:60mm; width:80mm;"
      },
      {
        "h3": { "en": "Direction Convention", "zh": "方向约定" },
        "body": { "en": "Top, bottom, left, and right throughout this manual refer to this view.", "zh": "本手册中提到的上、下、左、右，都以此视图为准。" },
        "classes": "note overlay sm",
        "style": "right:16mm; bottom:140mm; width:80mm;"
      },
      {
        "h3": { "en": "Counterbores face out", "zh": "沉孔朝外" },
        "body": { "en": "The counterbored ends of the long extrusions face outboard, each counterbore aligned with the short extrusion's end bore.", "zh": "长型材带沉孔的一端朝外，每个沉孔对准短型材的端面孔。" },
        "classes": "note overlay sm",
        "style": "right:16mm; bottom:100mm; width:80mm;"
      }
    ],
    "bom": {
      "label": { "en": "Bill of materials", "zh": "物料清单" },
      "rows": [
