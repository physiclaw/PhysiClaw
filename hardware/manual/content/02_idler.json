    "secnum": { "en": "SECTION 02", "zh": "第 02 节" },
    "h1": { "en": "Idler", "zh": "惰轮" },
    "lede": { "en": "Install one idler assembly at each of the four corners of the frame, all using smooth idlers. They roll against the flat back side of the GT2 belt, redirecting it around each corner.", "zh": "框架四角各装一个惰轮组，全用光面惰轮。惰轮贴着 GT2 同步带的平背面滚动，在转角处把同步带引导转向。" }
  },
  {
    "type": "tall-left",
    "page": "idler_10",
    "head": { "title": { "en": "IDLER", "zh": "惰轮" }, "small": "idler_10" },
