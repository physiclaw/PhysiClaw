[
  {
    "type": "opener",
    "page": "idler",
    "secnum": { "en": "SECTION 02", "zh": "第 02 节" },
    "h1": { "en": "Idler", "zh": "惰轮" },
    "lede": { "en": "Install one idler assembly at each of the four corners of the frame, all using smooth idlers. They roll against the flat back side of the GT2 belt, redirecting it around each corner.", "zh": "框架四角各装一个惰轮组，全用光面惰轮。惰轮贴着 GT2 同步带的平背面滚动，在转角处引导同步带转向。" }
  },
  {
    "type": "tall-left",
    "page": "idler_10",
    "head": { "title": { "en": "IDLER", "zh": "惰轮" }, "small": "idler_10" },
    "figures": [
      { "src": "idler_10_lu_exploded_cam0.svg" },
      { "src": "idler_10_lu_assembled_cam0.svg" }
    ],
    "notes": [
      {
        "h3": { "en": "Center hardware first", "zh": "先装中间的螺栓螺母" },
        "body": { "en": "Drop the center M5 square nut and its M5×10 BHCS into the middle counterbore hole first — the stacks block access later.", "zh": "先把中间的 M5 四方螺母和 M5×10 半圆头螺栓放进中间的沉孔——两侧惰轮柱装上后，这里就伸不进去了。" },
        "classes": "note overlay sm",
        "style": "left:105mm; top:70mm; width:80mm;"
      },
      {
        "h3": { "en": "Confirm the idler spins freely", "zh": "确认惰轮转得顺畅" },
        "body": { "en": "Once installed, check that each idler turns freely.", "zh": "装好后逐个转一下，确认每个惰轮都能自由转动。" },
        "classes": "note overlay sm",
        "style": "left:135mm; top:100mm; width:70mm;"
      },
      {
        "h3": { "en": "Flat face toward the screw", "zh": "平的一面朝着螺栓" },
        "body": { "en": "Seat each square nut with its flat face pointing toward its screw.", "zh": "放四方螺母时，让平的一面朝向它对应的螺栓。" },
        "classes": "note overlay sm",
        "style": "left:135mm; top:130mm; width:70mm;"
      },
      {
        "h3": { "en": "Side pocket hard to seat?", "zh": "侧面槽位放不进？" },
        "body": { "en": "If a side square nut won't drop into place, clear the pocket with a small screwdriver or a pin first — prints can leave residue in the slot.", "zh": "如侧面四方螺母难以放到位，先用小螺丝刀或细针清理槽孔——打印件槽内可能有残留。" },
        "classes": "note overlay sm",
        "style": "left:135mm; top:155mm; width:70mm;"
      }
    ],
    "bom": {
      "label": { "en": "Bill of materials", "zh": "物料清单" },
      "rows": [
        { "component": { "en": "Idler mount", "zh": "惰轮支座" }, "spec": { "en": "SLS/MJF 3D Print", "zh": "SLS/MJF 3D 打印" }, "qty": "1" },
        { "component": { "en": "Idler", "zh": "惰轮" }, "spec": { "en": "GT2 20T, smooth", "zh": "GT2 20T，光面" }, "qty": "3" },
