    ],
    "notes": [
      {
        "h3": { "en": "Two ways to the frame", "zh": "两处锁紧到框架" },
        "body": { "en": "The block locks to the frame in two places: the middle M5 screw catches a slide-in T-nut in the extrusion slot, and the bracket bridges block and frame.", "zh": "支座靠两处锁紧在框架上：中间的 M5 螺钉咬住型材槽里的滑入式 T 型螺母，连接板再把支座和框架连在一起。" },
        "classes": "note overlay sm",
        "style": "left:110mm; top:30mm; width:80mm;"
      },
      {
        "h3": { "en": "2 mm gap to the corner plate", "zh": "与转角板留 2 mm 间隙" },
        "body": { "en": "Position the block so it sits 2 mm clear of the frame-corner joining plate — the bracket that reinforces the frame joint, not the one mounted here.", "zh": "调整支座位置，使它离框架转角连接板留出 2 mm 间隙——这里指加固框架接头的那块连接板，不是此处安装的这块。" },
        "classes": "note overlay sm",
        "style": "left:110mm; top:72mm; width:80mm;"
      }
    ],
    "bom": {
      "label": { "en": "Bill of materials", "zh": "物料清单" },
      "rows": [
        { "component": { "en": "bracket", "zh": "连接板" }, "spec": "Joining Plate", "qty": "1" },
        { "component": { "en": "BHCS", "zh": "BHCS" }, "spec": "M5×10", "qty": "2" },
        { "component": { "en": "T-nut", "zh": "T 型螺母" }, "spec": "Drop-In M5", "qty": "1" }
      ]
    }
  },
  {
