      { "src": "idler_10_lu_assembled_cam0.svg" }
    ],
    "notes": [
      {
        "h3": { "en": "Center hardware first", "zh": "先装中间的紧固件" },
        "body": { "en": "Drop the center M5 square nut and its M5×10 BHCS into the middle counterbore hole first — the stacks block access later.", "zh": "先把中间的 M5 方螺母连同 M5×10 BHCS 放进中间的沉孔，后面叠装上去就够不到这里了。" },
        "classes": "note overlay sm",
        "style": "left:105mm; top:70mm; width:80mm;"
      },
      {
        "h3": { "en": "Confirm the idler spins freely", "zh": "确认惰轮转动顺畅" },
        "body": { "en": "Once installed, check that each idler turns freely.", "zh": "装好后，逐个确认惰轮都能自由转动。" },
        "classes": "note overlay sm",
        "style": "left:130mm; top:100mm; width:78mm;"
      },
      {
        "h3": { "en": "Flat face toward the screw", "zh": "平面朝向螺钉" },
        "body": { "en": "Seat each square nut with its flat face pointing toward its screw.", "zh": "放置每个方螺母时，让平面一侧朝向对应的螺钉。" },
        "classes": "note overlay sm",
        "style": "left:130mm; top:140mm; width:78mm;"
      }
    ],
