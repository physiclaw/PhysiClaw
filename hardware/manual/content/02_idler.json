    "notes": [
      {
        "h3": { "en": "Shims set the play", "zh": "垫片决定间隙大小" },
        "body": { "en": "The 0.5 mm shim sets how much axial play each idler has. Thickness varies between suppliers — measure yours and confirm 0.5 mm before stacking, or the idler will bind or run loose.", "zh": "0.5 mm 的垫片决定每个惰轮在轴向上能动多少。不同供应商的厚度不一样，叠装前先量一下，确认是 0.5 mm，不然惰轮要么卡住、要么太松。" },
        "classes": "note overlay sm",
        "style": "left:105mm; top:40mm; width:80mm;"
      },
      {
        "h3": { "en": "Spacer must total 9 mm", "zh": "轴套总高要够 9 mm" },
        "body": { "en": "The spacer is 9 mm tall. If you can't buy that exact height, stack shorter spacers to total 9 mm.", "zh": "轴套高 9 mm。买不到正好这个高度，就拿几个矮一点的叠起来凑够 9 mm。" },
        "classes": "note overlay sm",
        "style": "left:110mm; top:82mm; width:80mm;"
      }
    ],
    "bom": {
      "label": { "en": "Bill of materials", "zh": "物料清单" },
      "rows": [
        { "component": { "en": "Idler mount", "zh": "惰轮支座" }, "spec": "SLS 3D Print", "qty": "1" },
        { "component": { "en": "Idler", "zh": "惰轮" }, "spec": "M5×6 20T smooth", "qty": "3" },
