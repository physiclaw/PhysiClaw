    "secnum": { "en": "SECTION 02", "zh": "第 02 节" },
    "h1": { "en": "Idler", "zh": "惰轮" },
    "lede": { "en": "Smooth pulleys route the GT2 belts around their corners. Four corner stations (LU, RU, LD, RD) carry the belt path, each built up in two or three steps.", "zh": "光面惰轮把 GT2 同步带导向各个转角。四个转角工位（LU、RU、LD、RD）共同构成同步带路径，每个工位分两到三步装好。" }
  },
  {
    "type": "tall-left",
    "page": "12",
    "head": { "title": { "en": "IDLER", "zh": "惰轮" }, "small": "idler_10" },
