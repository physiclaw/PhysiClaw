    "figures": [
      { "src": "idler_12_lu_exploded_cam1_dgik.svg" },
      { "src": "idler_12_lu_assembled_cam0_swuy.svg", "style": "object-position: 64% center;" }
    ],
    "notes": [
      {
        "h3": { "en": "Two ways to the frame", "zh": "两处固定到框架" },
        "body": { "en": "The block locks to the frame in two places: the middle M5 screw catches a slide-in T-nut in the extrusion slot, and the bracket bridges block and frame.", "zh": "支座靠两处固定在框架上：中间的 M5 螺栓咬住型材槽里的滑块螺母，再用一块连接板把支座和框架连到一起。" },
        "classes": "note overlay sm",
        "style": "left:110mm; top:30mm; width:80mm;"
      },
      {
        "h3": { "en": "2 mm gap to the corner plate", "zh": "与转角连接板留 2 mm 间隙" },
        "body": { "en": "Position the block so it sits 2 mm clear of the frame-corner joining plate — the bracket that reinforces the frame joint, not the one mounted here.", "zh": "摆放支座时，让它离框架转角的连接板留出 2 mm 间隙——这块连接板加固框架接头，不是这一步要装的那块。" },
        "classes": "note overlay sm",
        "style": "left:110mm; top:72mm; width:80mm;"
      }
    ],
    "bom": {
      "label": { "en": "Bill of materials", "zh": "物料清单" },
      "rows": [
        { "component": { "en": "bracket", "zh": "连接板" }, "spec": "Joining Plate", "qty": "1" },
        { "component": { "en": "BHCS", "zh": "半圆头螺栓" }, "spec": "M5×10", "qty": "2" },
        { "component": { "en": "T-nut", "zh": "T 型螺母" }, "spec": "Drop-In M5", "qty": "1" }
      ]
    }
  },
  {
    "type": "tall-left",
    "page": "idler_20",
    "head": { "title": { "en": "IDLER", "zh": "惰轮" }, "small": "idler_20" },
