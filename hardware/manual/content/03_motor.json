    "secnum": { "en": "SECTION 03", "zh": "第 03 节" },
    "h1": { "en": "Motor", "zh": "电机" },
    "lede": { "en": "Two NEMA 17 stepper motors mount on the top extrusions of the frame, one on each side. They drive the CoreXY belts, which move the stylus carriage.", "zh": "两个 42 步进电机装在框架顶部的型材上，左右各一，驱动 CoreXY 同步带，带动触控笔滑座移动。" }
  },
  {
    "type": "tall-left",
    "page": "motor_10",
    "head": { "title": { "en": "MOTOR", "zh": "电机" }, "small": "motor_10" },
    "figures": [
      { "src": "motor_10_bracket_exploded_cam1.svg" },
      { "src": "motor_10_bracket_assembled_cam1.svg" }
    ],
    "notes": [
      {
        "h3": { "en": "Note the motor wire direction", "zh": "注意电机引线的朝向" },
        "body": { "en": "Check which way the motor's wires face and match the orientation shown — it sets the wiring clearance later.", "zh": "看清电机引线朝哪个方向，按图里的朝向装好——它关系到后面布线时留出的空间。" },
        "classes": "note overlay sm",
        "style": "left:130mm; top:130mm; width:80mm;"
      },
      {
        "h3": { "en": "Only the spacer height matters", "zh": "只有轴套高度有要求" },
        "body": { "en": "The Motor A spacer must be 8 mm tall. Any bore over 5 mm (to clear the M5 screw) and outer diameter over 8 mm and up to 20 mm will do, or stack shorter spacers to total 8 mm.", "zh": "电机 A 轴套高度必须是 8 mm。内孔大于 5 mm（能让 M5 螺栓穿过）、外径在 8 mm 到 20 mm 之间就行；也可以用几个矮的叠起来凑够 8 mm。" },
        "classes": "note overlay sm",
        "style": "left:100mm; top:20mm; width:80mm;"
      },
      {
        "h3": { "en": "Tighten in a cross pattern", "zh": "按对角顺序拧紧" },
        "body": { "en": "Run all four motor screws in finger-tight first, then tighten opposite corners in pairs. This pulls the motor flat against the bracket instead of tilting it to one side.", "zh": "先把四颗电机螺栓都用手拧到位，再两两对角拧紧。这样电机才能平贴在支架上，不会歪向一边。" },
        "classes": "note overlay sm",
        "style": "left:125mm; top:75mm; width:70mm;"
      }
    ],
    "bom": {
      "label": { "en": "Bill of materials", "zh": "物料清单" },
      "rows": [
        { "component": { "en": "Motor bracket", "zh": "电机支架" }, "spec": "60×42×3", "qty": "1" },
        { "component": { "en": "Stepper motor", "zh": "步进电机" }, "spec": "NEMA 17, 38 mm", "qty": "1" },
        { "component": { "en": "BHCS", "zh": "半圆头螺栓" }, "spec": "M3×6", "qty": "4" },
        { "component": { "en": "BHCS", "zh": "半圆头螺栓" }, "spec": "M5×20", "qty": "2" },
        { "component": { "en": "Spacer", "zh": "轴套" }, "spec": "M6 (Ø20×8)", "qty": "2" }
      ]
    }
  },
