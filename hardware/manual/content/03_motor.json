    "secnum": { "en": "SECTION 03", "zh": "第 03 节" },
    "h1": { "en": "Motor", "zh": "电机" },
    "lede": { "en": "Brackets, frame-side mounts, and pulleys carry the two NEMA-17 steppers. These drive the CoreXY belt path that moves the stage.", "zh": "两台 NEMA-17 步进电机由支架、框架侧安装件和同步带轮固定。电机驱动 CoreXY 同步带路径，带动运动平台移动。" }
  },
  {
    "type": "tall-left",
    "page": "21",
    "head": { "title": { "en": "MOTOR", "zh": "电机" }, "small": "motor_10" },
    "figures": [
      { "src": "motor_10_bracket_exploded_cam1.svg" },
      { "src": "motor_10_bracket_assembled_cam1.svg" }
    ],
    "notes": [
      {
        "h3": { "en": "Note the motor wire direction", "zh": "注意电机引线方向" },
        "body": { "en": "Check which way the motor's wires face and match the orientation shown — it sets the wiring clearance later.", "zh": "看清电机引线朝哪个方向，并与图示一致——它决定后续的布线间隙。" },
        "classes": "note overlay sm",
        "style": "left:130mm; top:130mm; width:80mm;"
      },
      {
        "h3": { "en": "Only the spacer height matters", "zh": "只有隔套高度有讲究" },
        "body": { "en": "The spacer must be 12 mm tall. Any bore over 5 mm (to clear the M5 screw) and outer diameter over 8 mm and up to 20 mm will do, or stack shorter spacers to total 12 mm.", "zh": "隔套高度必须为 12 mm。内孔大于 5 mm（让过 M5 螺钉）、外径在 8 mm 以上、20 mm 以内即可；也可叠放几个较短的隔套，凑足 12 mm。" },
        "classes": "note overlay sm",
        "style": "left:100mm; top:20mm; width:80mm;"
      },
      {
        "h3": { "en": "Tighten in a cross pattern", "zh": "按对角顺序拧紧" },
        "body": { "en": "Run all four motor screws in finger-tight first, then tighten opposite corners in pairs. This pulls the motor flat against the bracket instead of tilting it to one side.", "zh": "先把四颗电机螺钉都手拧到位，再两两对角拧紧。这样电机会平贴在支架上，不会偏向一侧。" },
        "classes": "note overlay sm",
        "style": "left:125mm; top:75mm; width:70mm;"
      }
    ],
    "bom": {
      "label": { "en": "Bill of materials", "zh": "物料清单" },
      "rows": [
        { "component": { "en": "Motor bracket", "zh": "电机支架" }, "spec": "60×41×1.9", "qty": "1" },
        { "component": { "en": "Stepper motor", "zh": "步进电机" }, "spec": "NEMA 17, 34 mm", "qty": "1" },
        { "component": { "en": "BHCS", "zh": "BHCS 内六角盘头螺钉" }, "spec": "M3×6", "qty": "4" },
        { "component": { "en": "BHCS", "zh": "BHCS 内六角盘头螺钉" }, "spec": "M5×20", "qty": "2" },
        { "component": { "en": "Spacer", "zh": "隔套" }, "spec": "M6 (Ø20×12)", "qty": "2" }
      ]
    }
