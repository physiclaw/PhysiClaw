  {
    "type": "main-inset-br",
    "page": "board_40",
    "head": { "title": { "en": "CONTROL BOARD", "zh": "控制板" }, "small": "board_40" },
    "main": { "src": "board_40_teflon_assembled_cam0_nrvk.svg", "style": "transform: translateX(-35mm);" },
    "notes": [
      {
        "h3": { "en": "Teflon tube", "zh": "特氟龙管" },
        "body": { "en": "Run the wires through the Teflon tube — it keeps them tidy and clear of the moving belts and motors.", "zh": "把导线穿进特氟龙管——既能理顺导线，又能让它们躲开运动的同步带和电机。" },
        "classes": "note overlay sm",
        "style": "right:30mm; top:30mm; width:90mm;"
      },
      {
        "h3": { "en": "Rough length", "zh": "大致长度" },
        "body": { "en": "Make the tube about 380 mm — long enough to reach from the control board to the X carriage at its farthest position.", "zh": "管子取大约 380 mm——从控制板够到 X 滑座最远位置即可。" },
        "classes": "note overlay sm",
        "style": "right:30mm; top:50mm; width:90mm;"
      },
      {
        "h3": { "en": "Extend the solenoid leads", "zh": "给电磁铁引线接长" },
        "body": { "en": "The solenoid's stock leads are too short to reach the board — splice on extra wire to connect the solenoid to the control board.", "zh": "电磁铁原装的引线太短，够不到板子——接一段导线，把电磁铁连到控制板上。" },
        "classes": "note overlay sm",
        "style": "right:30mm; top:80mm; width:90mm;"
      },
      {
        "h3": { "en": "PTFE vs FEP", "zh": "PTFE 和 FEP" },
        "body": { "en": "Either tube works here — PTFE (milky white) or FEP (clear). The toughness/stiffness is enough to support the wire.", "zh": "两种管子都能用——PTFE（乳白色）或 FEP（透明）。韧性和硬度足够撑住导线。" },
        "classes": "note overlay sm",
        "style": "right:30mm; top:110mm; width:90mm;"
      }
    ],
    "bom": {
      "label": { "en": "Bill of materials", "zh": "物料清单" },
      "rows": [
        { "component": { "en": "Teflon tube", "zh": "特氟龙管" }, "spec": "Ø6/5, 380 mm", "qty": "1" }
