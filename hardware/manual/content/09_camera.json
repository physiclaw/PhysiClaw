    "notes": [
      {
        "h3": { "en": "Thread on the camera", "zh": "拧上摄像头" },
        "body": { "en": "Thread the camera's 1/4-20 female socket onto the gooseneck's male stud until it bottoms on the stud collar. The camera now hangs off the neck tip.", "zh": "把摄像头的 1/4-20 内螺纹接口拧上金属软管的外螺纹螺柱，拧到底面顶住螺柱台肩。摄像头现在挂在软管顶端。" },
        "classes": "note overlay sm",
        "style": "left:140mm; top:80mm; width:60mm;"
      }
    ],
    "bom": {
      "label": { "en": "Bill of materials", "zh": "物料清单" },
      "rows": [
        { "component": { "en": "Camera", "zh": "摄像头" }, "spec": { "en": "4K HD, autofocus", "zh": "4K 高清，自动对焦" }, "qty": "1" }
      ]
    }
  },
  {
    "type": "main-inset-br",
    "page": "camera_40",
    "head": { "title": { "en": "CAMERA", "zh": "摄像头" }, "small": "camera_40" },
    "main": { "src": "camera_40_frame_assembled_cam1_mxqc.svg", "style": "transform: translateX(-35mm);" },
    "notes": [
      {
        "h3": { "en": "Use the lower slot", "zh": "用下面的型材槽" },
        "body": { "en": "Mount the corner bracket on the lower slot of the right extrusion's outer face.", "zh": "把角码装在右侧型材外侧面下方的型材槽上。" },
        "classes": "note overlay sm",
        "style": "right:30mm; top:30mm; width:60mm;"
      },
      {
        "h3": { "en": "Orient the camera", "zh": "调摄像头的朝向" },
        "body": { "en": "Bend the gooseneck to frame the screen, and mount the camera in landscape — sensor's long axis parallel to the phone's long edge.", "zh": "弯一弯金属软管，让屏幕进到画面里。摄像头横着装，传感器长边对齐手机长边。" },
        "classes": "note overlay sm",
        "style": "right:30mm; top:80mm; width:60mm;"
      },
      {
        "h3": { "en": "Lock it down", "zh": "固定牢" },
        "body": { "en": "Make sure the camera is held firm — it shouldn't drift or wobble.", "zh": "确认摄像头已固定牢靠，不会移位，也不会晃动。" },
        "classes": "note overlay sm",
        "style": "right:30mm; top:140mm; width:60mm;"
      },
      {
        "h3": { "en": "Route the USB cable", "zh": "整理 USB 线" },
        "body": { "en": "Secure the camera's USB cable along the gooseneck to keep it clear of the belt.", "zh": "把摄像头的 USB 线沿着金属软管固定好，别让它碰到同步带。" },
        "classes": "note overlay sm",
        "style": "left:16mm; top:30mm; width:72mm;"
      }
    ]
  }
]
