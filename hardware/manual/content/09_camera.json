    "notes": [
      {
        "h3": { "en": "Use the lower slot", "zh": "用下方型材槽" },
        "body": { "en": "Mount the corner bracket on the lower slot of the right extrusion's outer face.", "zh": "把角支架装在右侧型材外侧面的下方型材槽上。" },
        "classes": "note overlay sm",
        "style": "right:30mm; top:30mm; width:60mm;"
      },
      {
        "h3": { "en": "Orient the camera", "zh": "调整摄像头朝向" },
        "body": { "en": "Bend the gooseneck to frame the screen, and mount the camera in landscape — sensor's long axis parallel to the phone's long edge.", "zh": "弯折鹅颈臂，让屏幕进入取景范围，并横向安装摄像头，使传感器长轴与手机长边平行。" },
        "classes": "note overlay sm",
        "style": "right:30mm; top:80mm; width:60mm;"
      },
      {
        "h3": { "en": "Lock it down", "zh": "锁紧固定" },
        "body": { "en": "Make sure the camera is held firm — it shouldn't drift or wobble.", "zh": "确认摄像头固定牢靠，不会移位或晃动。" },
        "classes": "note overlay sm",
        "style": "right:30mm; top:140mm; width:60mm;"
      },
      {
        "h3": { "en": "Route the USB cable", "zh": "布置 USB 线缆" },
        "body": { "en": "Secure the camera's USB cable along the gooseneck to keep it clear of the belt.", "zh": "把摄像头的 USB 线缆沿鹅颈臂固定好，避开同步带。" },
        "classes": "note overlay sm",
        "style": "left:16mm; top:30mm; width:72mm;"
      }
    ]
  }
